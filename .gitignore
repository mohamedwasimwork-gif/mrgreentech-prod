# ---- OS / editor ----
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
.fleet/

# ---- Node / Next.js (web/) ----
node_modules/
.next/
out/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Python / FastAPI (backend/) ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- App data ----
# Local SQLite — production uses Postgres on Neon, never commit the dev DB.
*.db
*.db-journal
*.sqlite3

# ---- Secrets ----
# Keep .env.example in source control (it's the template); never commit .env.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Cloudflare Pages reads NEXT_PUBLIC_* from the build env; .env.production is
# the in-repo source of truth and is safe to commit because the URL is public.
!.env.production
!.env.example

# ---- Build artefacts / temp ----
*.tsbuildinfo
dist/
build/
coverage/
