# MR Greentech backend — copy to .env and edit before running in production

# JWT signing key. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-this-is-only-for-local-dev-do-not-ship

# Hours a login token is valid for
ACCESS_TOKEN_HOURS=12

# CORS origins allowed to hit the API (comma separated). Localhost dev default.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SQLite database file (relative to backend/)
DATABASE_URL=sqlite:///./mrgreentech.db

# Seed admin user (created on first run if no users exist).
# NOTE: special characters in the password are fine here — the .env loader does
# NOT do shell-style variable expansion, so $ and # are preserved literally.
SEED_ADMIN_EMAIL=admin@mrgreentech.com
SEED_ADMIN_PASSWORD=P@$$word@123
SEED_ADMIN_NAME=Admin
